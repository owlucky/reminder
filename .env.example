# Скопируйте в .env и заполните значения.

# Токен Telegram-бота (получить у @BotFather). Обязателен для канала telegram
# и для интерактивного бота.
TELEGRAM_BOT_TOKEN=

# Запускать ли интерактивного бота (long polling). true/false.
TELEGRAM_BOT_POLLING=true

# База данных. По умолчанию — локальный SQLite-файл (легковесно, без внешних зависимостей).
DATABASE_URL=sqlite:///./data/reminders.db

# Как часто планировщик проверяет наступившие напоминания (в секундах).
POLL_INTERVAL_SECONDS=30

# На сколько секунд назад "досылать" пропущенные напоминания (например, после простоя/рестарта).
# По умолчанию 6 часов. Дедупликация не даст отправить одно и то же дважды.
MISSED_GRACE_SECONDS=21600

# Срок временного отключения по умолчанию (в днях) для действия snooze ("не напоминать месяц").
DEFAULT_SNOOZE_DAYS=30

# Уровень логирования.
LOG_LEVEL=INFO
